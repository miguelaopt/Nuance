{
    "manifest_version": 3,
    "name": "__MSG_appName__",
    "version": "1.0",
    "description": "__MSG_appDescription__",
    "default_locale": "en",
    "permissions": [
      "activeTab",
      "scripting"
    ],
    "host_permissions": [
      "<all_urls>"
    ],
    "background": {
      "service_worker": "background.js"
    },
    "content_scripts": [
      {
        "matches": ["<all_urls>"],
        "js": ["content.js"]
      }
    ],
    "action": {
      "default_title": "__MSG_actionTitle__"
    }
  }